rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated and has the 'doctor' role
    function isDoctor() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only manageable through backend/admin console
    }

    match /patients/{patientId} {
      // Doctors can read patient data. Patient can read their own data.
      allow read: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
      
      // Only doctors can create new patients
      allow create: if isDoctor();
      
      // Update allowed only for doctors, or patient updating their own emergency profile
      // For simplicity, we'll let doctors update everything, and patients update only if they are the owner
      allow update: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
      allow delete: if false; // Deletions not allowed

      match /records/{recordId} {
        // Read: Doctors can read. Patients can read their own records.
        allow read: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
        
        // Create: ONLY doctors can create records. 
        allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
        
        // NO UPDATE OR DELETE ALLOWED (Immutable records)
        allow update, delete: if false;
      }
    }
  }
}
