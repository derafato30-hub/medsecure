rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isDoctor() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow user to write their initial 'patient' role on signup
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'patient';
      allow write: if isAdmin();
    }

    match /doctors_directory/{docId} {
      // Public or authenticated read? Let's keep it authenticated read for now, or public if needed.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /patients/{patientId} {
      // URGENT FIX: Allow public read so /emergency/:dni works without login
      allow read: if true;
      
      // Allow doctor to create, OR the patient themselves (from public signup)
      allow create: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
      
      // Update allowed only for doctors, or patient updating their own emergency profile
      allow update: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
      allow delete: if false;

      match /records/{recordId} {
        // Records remain STRICTLY protected
        allow read: if isDoctor() || (request.auth != null && request.auth.uid == patientId);
        allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
        // NO UPDATE OR DELETE ALLOWED
        allow update, delete: if false;
      }
    }
  }
}
